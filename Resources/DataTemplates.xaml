<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:ScriptureTyping.ViewModels"
                    xmlns:v="clr-namespace:ScriptureTyping.Views"
                    xmlns:gvm="clr-namespace:ScriptureTyping.ViewModels.Games"
                    xmlns:gvmWordOrder="clr-namespace:ScriptureTyping.ViewModels.Games.WordOrder"
                    xmlns:gv="clr-namespace:ScriptureTyping.Views.Games">

    <!-- 오른쪽 화면: CourseSelect -->
    <DataTemplate DataType="{x:Type vm:CourseSelectViewModel}">
        <v:CourseSelect/>
    </DataTemplate>

    <!-- 오른쪽 화면: Placeholder -->
    <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
        <Grid Margin="24" Background="{StaticResource Brush.Bg}">
            <Border Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               Foreground="{StaticResource Brush.Text}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding Message}"
                               Foreground="{StaticResource Brush.Text2}"
                               FontSize="14"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>

    <!-- 게임 허브 -->
    <DataTemplate DataType="{x:Type gvm:GamesHubViewModel}">
        <gv:GamesHub/>
    </DataTemplate>

    <!-- 게임 5개 -->
    <DataTemplate DataType="{x:Type gvm:ClozeGameViewModel}">
        <gv:ClozeGame/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type gvmWordOrder:WordOrderGameViewModel}">
        <gv:WordOrderGame/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type gvm:MistakeHuntGameViewModel}">
        <gv:MistakeHuntGame/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type gvm:InitialsRecallGameViewModel}">
        <gv:InitialsRecallGame/>
    </DataTemplate>

</ResourceDictionary>