<UserControl x:Class="ScriptureTyping.Views.Games.Cloze.Controls.DualChoiceGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="DefaultChoiceButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#B8C6D8"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F8FBFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EAF2FF"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="DefaultChoiceItemTemplate">
            <Button Content="{Binding Text}"
                    Command="{Binding Command}"
                    CommandParameter="{Binding CommandParameter}"
                    IsEnabled="{Binding IsEnabled}"
                    Style="{StaticResource DefaultChoiceButtonStyle}"/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F3F6FB"
                BorderBrush="#D7DFEA"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding TopTitle, ElementName=Root}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1F2937"
                           Visibility="{Binding HasTopTitle, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding TopItemsSource, ElementName=Root}"
                              ItemTemplate="{Binding EffectiveTopItemTemplate, ElementName=Root}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding TopDisplayColumns, ElementName=Root}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#F3F6FB"
                BorderBrush="#D7DFEA"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding BottomTitle, ElementName=Root}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1F2937"
                           Visibility="{Binding HasBottomTitle, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding BottomItemsSource, ElementName=Root}"
                              ItemTemplate="{Binding EffectiveBottomItemTemplate, ElementName=Root}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding BottomDisplayColumns, ElementName=Root}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>