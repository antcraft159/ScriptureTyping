<UserControl x:Class="ScriptureTyping.Views.RecitingMusic.RecitingMusicView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:ScriptureTyping.Converters"
             mc:Ignorable="d"
             Unloaded="RecitingMusicView_Unloaded">

    <UserControl.Resources>
        <converters:SecondsToTimeTextConverter x:Key="SecondsToTimeTextConverter"/>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource Brush.Surface2}"/>
                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource Brush.Text2}"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource Brush.Border}"/>
                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource Brush.Text}"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Muted}"/>
                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Text2}"/>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DisplayTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="가능">
                    <Setter Property="Foreground" Value="#22C55E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="불가능">
                    <Setter Property="Foreground" Value="#EF4444"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="완료">
                    <Setter Property="Foreground" Value="#60A5FA"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="{StaticResource Layout.MenuSafeMargin}">
        <Grid Margin="24"
              Background="{DynamicResource Brush.Bg}">

            <Border Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,16">
                        <TextBlock FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Text}">
                            <TextBlock.Text>
                                <Binding Path="Title"
                                         FallbackValue="암송을 즐겁게"/>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource Brush.Text2}"
                                   FontSize="14"
                                   TextWrapping="Wrap">
                            <TextBlock.Text>
                                <Binding Path="Description"
                                         FallbackValue="노래 목록과 가사를 확인할 수 있습니다."/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="전체 곡 수"
                                           Foreground="{DynamicResource Brush.Muted}"
                                           FontSize="13"/>
                                <TextBlock Foreground="{DynamicResource Brush.Text}"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0">
                                    <TextBlock.Text>
                                        <Binding Path="TotalCount"
                                                 FallbackValue="0"
                                                 TargetNullValue="0"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="현재 목록"
                                           Foreground="{DynamicResource Brush.Muted}"
                                           FontSize="13"/>
                                <TextBlock Foreground="{DynamicResource Brush.Text}"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0">
                                    <TextBlock.Text>
                                        <Binding Path="FilteredCount"
                                                 FallbackValue="0"
                                                 TargetNullValue="0"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="가능"
                                           Foreground="{DynamicResource Brush.Muted}"
                                           FontSize="13"/>
                                <TextBlock Foreground="{DynamicResource Brush.Text}"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0">
                                    <TextBlock.Text>
                                        <Binding Path="ReadyCount"
                                                 FallbackValue="0"
                                                 TargetNullValue="0"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6" Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="불가능"
                                           Foreground="{DynamicResource Brush.Muted}"
                                           FontSize="13"/>
                                <TextBlock Foreground="{DynamicResource Brush.Text}"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0">
                                    <TextBlock.Text>
                                        <Binding Path="UnavailableCount"
                                                 FallbackValue="0"
                                                 TargetNullValue="0"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,0,0,16"
                            Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="과정"
                                       Foreground="{DynamicResource Brush.Text}"
                                       FontWeight="SemiBold"/>

                            <ComboBox Grid.Column="1"
                                      Height="36"
                                      Margin="8,0,0,0"
                                      ItemsSource="{Binding Courses}"
                                      SelectedItem="{Binding SelectedCourse, Mode=TwoWay}"/>

                            <TextBlock Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Text="일차"
                                       Foreground="{DynamicResource Brush.Text}"
                                       FontWeight="SemiBold"/>

                            <ComboBox Grid.Column="4"
                                      Height="36"
                                      Margin="8,0,0,0"
                                      ItemsSource="{Binding Days}"
                                      SelectedItem="{Binding SelectedDay, Mode=TwoWay}"/>

                            <Button Grid.Column="6"
                                    Height="36"
                                    Content="조회"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ApplyFilterCommand}"/>

                            <Button Grid.Column="8"
                                    Height="36"
                                    Content="초기화"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ResetFilterCommand}"/>

                            <TextBlock Grid.Column="9"
                                       Margin="16,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Text2}"
                                       FontSize="13">
                                <TextBlock.Text>
                                    <Binding Path="CurrentFilterText"
                                             FallbackValue="필터를 선택하세요."/>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.6*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="1.4*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource PanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="노래 목록"
                                           Foreground="{DynamicResource Brush.Text}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,12"/>

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding FilteredItems}"
                                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          RowHeaderWidth="0"
                                          Background="{DynamicResource Brush.Surface2}"
                                          Foreground="{DynamicResource Brush.Text}"
                                          FontSize="20"
                                          BorderThickness="0"
                                          RowBackground="{DynamicResource Brush.Surface2}"
                                          AlternatingRowBackground="{DynamicResource Brush.Surface}"
                                          HorizontalGridLinesBrush="{DynamicResource Brush.Border}"
                                          VerticalGridLinesBrush="{DynamicResource Brush.Border}"
                                          AlternationCount="2">

                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="Padding" Value="10,8"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>

                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="8,6"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>

                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                                            <Setter Property="Background" Value="{DynamicResource Brush.Surface2}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="Margin" Value="0,1,0,1"/>
                                            <Setter Property="SnapsToDevicePixels" Value="True"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridRow">
                                                        <Border x:Name="RowBorder"
                                                                Margin="{TemplateBinding Margin}"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                SnapsToDevicePixels="True">
                                                            <SelectiveScrollingGrid>
                                                                <SelectiveScrollingGrid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </SelectiveScrollingGrid.ColumnDefinitions>

                                                                <SelectiveScrollingGrid.RowDefinitions>
                                                                    <RowDefinition Height="*"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </SelectiveScrollingGrid.RowDefinitions>

                                                                <DataGridCellsPresenter Grid.Column="1"
                                                                                        ItemsPanel="{TemplateBinding ItemsPanel}"
                                                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>

                                                                <DataGridDetailsPresenter Grid.Row="1"
                                                                                          Grid.Column="1"
                                                                                          Visibility="{TemplateBinding DetailsVisibility}"/>
                                                            </SelectiveScrollingGrid>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>

                                            <Style.Triggers>
                                                <Trigger Property="AlternationIndex" Value="1">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
                                                </Trigger>

                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#DCEEFF"/>
                                                    <Setter Property="BorderBrush" Value="#38BDF8"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </Trigger>

                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
                                                </Trigger>

                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" Value="#CFE8FF"/>
                                                    <Setter Property="BorderBrush" Value="#38BDF8"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </MultiTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="번호"
                                                            Width="60"
                                                            ElementStyle="{StaticResource DisplayTextStyle}">
                                            <DataGridTextColumn.Binding>
                                                <Binding Path="Number" Mode="OneWay"/>
                                            </DataGridTextColumn.Binding>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="과정"
                                                            Width="90"
                                                            ElementStyle="{StaticResource DisplayTextStyle}">
                                            <DataGridTextColumn.Binding>
                                                <Binding Path="Course" Mode="OneWay"/>
                                            </DataGridTextColumn.Binding>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="일차"
                                                            Width="90"
                                                            ElementStyle="{StaticResource DisplayTextStyle}">
                                            <DataGridTextColumn.Binding>
                                                <Binding Path="Day" Mode="OneWay"/>
                                            </DataGridTextColumn.Binding>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="구절"
                                                            Width="220"
                                                            ElementStyle="{StaticResource DisplayTextStyle}">
                                            <DataGridTextColumn.Binding>
                                                <Binding Path="Reference" Mode="OneWay"/>
                                            </DataGridTextColumn.Binding>
                                        </DataGridTextColumn>

                                        <DataGridTemplateColumn Header="상태"
                                                                Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Status}"
                                                               Style="{StaticResource StatusTextStyle}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource PanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="가사"
                                           Foreground="{DynamicResource Brush.Text}"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>

                                <StackPanel Grid.Row="4"
                                            Orientation="Horizontal">
                                    <Button Width="70"
                                            Height="36"
                                            Margin="0,0,8,0"
                                            Content="-10"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="SeekBackwardButton_Click"/>

                                    <Button Width="90"
                                            Height="36"
                                            Margin="0,0,8,0"
                                            Content="재생"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding PlaySelectedCommand}"/>

                                    <Button Width="90"
                                            Height="36"
                                            Margin="0,0,8,0"
                                            Content="정지"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding StopPlaybackCommand}"/>

                                    <Button Width="70"
                                            Height="36"
                                            Content="+10"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="SeekForwardButton_Click"/>
                                </StackPanel>

                                <Grid Grid.Row="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Foreground="{DynamicResource Brush.Muted}"
                                                   FontSize="12"
                                                   Text="{Binding CurrentTimeText}"/>

                                        <TextBlock Grid.Column="2"
                                                   Foreground="{DynamicResource Brush.Muted}"
                                                   FontSize="12"
                                                   Text="{Binding TotalDurationText}"/>
                                    </Grid>

                                    <Grid Grid.Row="2"
                                          x:Name="PlaybackSliderHost">
                                        <Slider x:Name="PlaybackSlider"
                                                Height="24"
                                                Minimum="0"
                                                Maximum="{Binding PlaybackProgressMaximum, Mode=OneWay}"
                                                Value="{Binding SeekBarValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                IsMoveToPointEnabled="True"
                                                ValueChanged="PlaybackSlider_ValueChanged"
                                                PreviewMouseLeftButtonDown="PlaybackSlider_PreviewMouseLeftButtonDown"
                                                PreviewMouseLeftButtonUp="PlaybackSlider_PreviewMouseLeftButtonUp"
                                                LostMouseCapture="PlaybackSlider_LostMouseCapture"/>

                                        <Popup x:Name="PlaybackSeekPopup"
                                               Placement="Relative"
                                               PlacementTarget="{Binding ElementName=PlaybackSliderHost}"
                                               AllowsTransparency="True"
                                               StaysOpen="True"
                                               Focusable="False"
                                               IsHitTestVisible="False">
                                            <Border Background="{DynamicResource Brush.Surface}"
                                                    BorderBrush="{DynamicResource Brush.Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="10,4">
                                                <TextBlock Foreground="{DynamicResource Brush.Text2}"
                                                           FontSize="12"
                                                           Text="{Binding ElementName=PlaybackSlider,
                                                                          Path=Value,
                                                                          Converter={StaticResource SecondsToTimeTextConverter}}"/>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </Grid>

                                <TextBlock Grid.Row="8"
                                           FontSize="13"
                                           TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Muted}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PlaybackStatusText}" Value="재생 가능">
                                                    <Setter Property="Foreground" Value="#22C55E"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PlaybackStatusText}" Value="불가능">
                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.Text>
                                        <Binding Path="PlaybackStatusText"
                                                 FallbackValue="곡을 선택하세요."/>
                                    </TextBlock.Text>
                                </TextBlock>

                                <TextBlock Grid.Row="10"
                                           Text="가사"
                                           Foreground="{DynamicResource Brush.Muted}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>

                                <Border Grid.Row="12"
                                        Background="{DynamicResource Brush.Surface}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14">
                                    <TextBox Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource Brush.Text}"
                                             FontSize="20"
                                             FontWeight="SemiBold"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             IsReadOnly="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Disabled"
                                             CaretBrush="Transparent">
                                        <TextBox.Text>
                                            <Binding Path="SelectedItem.LyricsPreview"
                                                     Mode="OneWay"
                                                     TargetNullValue="선택한 음악의 가사가 여기에 표시됩니다."
                                                     FallbackValue="선택한 음악의 가사가 여기에 표시됩니다."/>
                                        </TextBox.Text>
                                    </TextBox>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>