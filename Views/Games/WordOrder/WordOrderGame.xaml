<UserControl x:Class="ScriptureTyping.Views.Games.WordOrderGame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             ClipToBounds="False">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.84"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="110"/>
        </Style>

        <Style x:Key="DifficultyListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="DifficultyListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="14,8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChoicePieceButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
    </UserControl.Resources>

    <Border Margin="{StaticResource Layout.MenuSafeMargin}"
            Padding="20,0,0,0">

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="2"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="← 뒤로"
                                Width="{StaticResource Layout.CommonWidth}"
                                Height="70"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding BackCommand}"/>

                        <StackPanel Grid.Column="2"
                                    Orientation="Vertical">

                            <TextBlock Text="{Binding Title}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Text}"/>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          Style="{StaticResource TopCombo}"
                                          ItemsSource="{Binding Courses}"
                                          SelectedItem="{Binding SelectedCourse, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <ComboBox Grid.Column="2"
                                          Style="{StaticResource TopCombo}"
                                          ItemsSource="{Binding Days}"
                                          SelectedItem="{Binding SelectedDay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <ListBox Grid.Column="4"
                                         Style="{StaticResource DifficultyListBox}"
                                         ItemContainerStyle="{StaticResource DifficultyListBoxItem}"
                                         ItemsSource="{Binding DifficultyOptions}"
                                         SelectedItem="{Binding SelectedDifficulty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         SelectionMode="Single"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         MinHeight="32">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                </ListBox>

                                <Button Grid.Column="6"
                                        Content="적용"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ApplySelectionCommand}"/>

                                <TextBlock Grid.Column="8"
                                           Text="{Binding SelectionError}"
                                           Foreground="#EF4444"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           Margin="12,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectionError}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectionError}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{StaticResource Brush.Bg}"
                            CornerRadius="8"
                            Padding="14">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding QuestionProgressText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding DifficultyText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="4"
                                           Text="{Binding HintText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="6"
                                           Text="{Binding TryText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="8"
                                           Text="{Binding TimerText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"
                                           Visibility="{Binding IsTimerVisible, Converter={StaticResource BoolToVis}}"/>
                            </Grid>

                            <Border Grid.Row="2"
                                    Style="{StaticResource PanelBorder}">
                                <StackPanel>
                                    <TextBlock Text="{Binding QuestionText}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource Brush.Text}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               LineHeight="26"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="4"
                                    Style="{StaticResource PanelBorder}">
                                <StackPanel>
                                    <TextBlock Text="{Binding FeedbackText}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource Brush.Text}"
                                               FontSize="15"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Style="{StaticResource PanelBorder}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="내가 만든 순서"
                                                   Foreground="{StaticResource Brush.Text}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>

                                        <Border Grid.Row="2"
                                                Background="{StaticResource Brush.Bg}"
                                                BorderBrush="{StaticResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10"
                                                MinHeight="110">
                                            <ItemsControl ItemsSource="{Binding SelectedPieces}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Text}"
                                                                Style="{StaticResource ChoicePieceButton}"
                                                                Command="{Binding DataContext.RemovePieceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2"
                                        Style="{StaticResource PanelBorder}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="보기 조각"
                                                   Foreground="{StaticResource Brush.Text}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>

                                        <Border Grid.Row="2"
                                                Background="{StaticResource Brush.Bg}"
                                                BorderBrush="{StaticResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10"
                                                MinHeight="110">
                                            <ItemsControl ItemsSource="{Binding AvailablePieces}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Text}"
                                                                Style="{StaticResource ChoicePieceButton}"
                                                                Command="{Binding DataContext.SelectPieceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                IsEnabled="{Binding DataContext.CanSelectPiece, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="힌트"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding HintCommand}"
                                        IsEnabled="{Binding IsHintEnabled}"/>

                                <Button Grid.Column="2"
                                        Content="전체 지우기"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ClearAllCommand}"
                                        IsEnabled="{Binding CanClearAll}"/>

                                <Button Grid.Column="4"
                                        Content="제출"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding SubmitCommand}"
                                        IsEnabled="{Binding CanSubmit}"/>

                                <Button Grid.Column="6"
                                        Content="다음 문제"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding NextQuestionCommand}"
                                        IsEnabled="{Binding CanGoNext}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>