<!-- 파일명: Views/Games/MistakeHuntGame.xaml -->
<UserControl x:Class="ScriptureTyping.Views.Games.MistakeHuntGame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <!-- 메뉴바 안전 영역 + 추가 왼쪽 여백 -->
    <Border Margin="{StaticResource Layout.MenuSafeMargin}"
            Padding="20,0,0,0">

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 본문 카드(표준 스타일 적용) -->
            <Border Grid.Row="2"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 헤더 -->
                    <DockPanel Grid.Row="0">
                        <Button Content="← 뒤로"
                                Height="32"
                                Padding="14,0"
                                Command="{Binding BackCommand}"/>

                        <TextBlock Text="{Binding Title}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="16,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text}"/>
                    </DockPanel>

                    <!-- 여기에 실제 게임 UI를 넣으면 됨 -->
                    <Border Grid.Row="2"
                            Background="{StaticResource Brush.Bg}"
                            CornerRadius="8"
                            Padding="12">
                        <TextBlock Text="여기부터 '오타 찾기' UI/로직을 구현하면 됨."
                                   Foreground="{StaticResource Brush.Text2}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>

            </Border>
        </Grid>
    </Border>
</UserControl>