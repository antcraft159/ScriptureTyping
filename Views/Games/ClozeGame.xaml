<UserControl x:Class="ScriptureTyping.Views.Games.ClozeGame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             ClipToBounds="False">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.84"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChoiceButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="TopCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="110"/>
        </Style>

        <Style x:Key="ChoiceGroupBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </UserControl.Resources>

    <Border Margin="{StaticResource Layout.MenuSafeMargin}"
            Padding="20,0,0,0">

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="2"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="← 뒤로"
                                Width="{StaticResource Layout.CommonWidth}"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding BackCommand}"/>

                        <StackPanel Grid.Column="2"
                                    Orientation="Vertical">

                            <TextBlock Text="{Binding Title}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Text}"/>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          Style="{StaticResource TopCombo}"
                                          ItemsSource="{Binding Courses}"
                                          SelectedItem="{Binding SelectedCourse, Mode=TwoWay}"/>

                                <ComboBox Grid.Column="2"
                                          Style="{StaticResource TopCombo}"
                                          ItemsSource="{Binding Days}"
                                          SelectedItem="{Binding SelectedDay, Mode=TwoWay}"/>

                                <ComboBox Grid.Column="4"
                                          Style="{StaticResource TopCombo}"
                                          ItemsSource="{Binding DifficultyOptions}"
                                          SelectedItem="{Binding SelectedDifficulty, Mode=TwoWay}"/>

                                <Button Grid.Column="6"
                                        Content="적용"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ApplySelectionCommand}"/>

                                <TextBlock Grid.Column="8"
                                           Text="{Binding SelectionError}"
                                           Foreground="#EF4444"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           Margin="12,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectionError}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectionError}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{StaticResource Brush.Bg}"
                            CornerRadius="8"
                            Padding="14">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding ProgressText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding ScoreText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="4"
                                           Text="{Binding ComboText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="6"
                                           Text="{Binding DifficultyText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="8"
                                           Text="{Binding TimeLeftText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"
                                           Visibility="{Binding IsTimeAttack, Converter={StaticResource BoolToVis}}"/>
                            </Grid>

                            <Border Grid.Row="2"
                                    Background="{StaticResource Brush.Surface}"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock Text="{Binding QuestionText}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource Brush.Text}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               LineHeight="26"/>

                                    <TextBlock Text="{Binding ReferenceText}"
                                               Margin="0,10,0,0"
                                               Foreground="{StaticResource Brush.Text2}"
                                               FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Grid.Row="4"
                                       Text="{Binding FeedbackText}"
                                       Foreground="{StaticResource Brush.Text2}"
                                       FontSize="25"
                                       TextWrapping="Wrap"/>

                            <Grid Grid.Row="6">
                                <!-- 단일 보기 -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding AreSingleChoicesVisible, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl ItemsSource="{Binding Choices}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="3"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding}"
                                                        Style="{StaticResource ChoiceButton}"
                                                        Command="{Binding DataContext.SelectChoiceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding DataContext.AreChoicesEnabled, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- 보통: 남는 공간을 위/아래 1:1로 채움 -->
                                <Grid Visibility="{Binding AreDualChoicesVisible, Converter={StaticResource BoolToVis}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- 첫 번째 보기 -->
                                    <Border Grid.Row="0"
                                            Style="{StaticResource ChoiceGroupBorder}"
                                            VerticalAlignment="Stretch">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Text="첫 번째 빈칸 보기"
                                                       Foreground="{StaticResource Brush.Text}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"/>

                                            <ScrollViewer Grid.Row="2"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding FirstChoices}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Columns="3"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Content="{Binding}"
                                                                    Style="{StaticResource ChoiceButton}"
                                                                    Command="{Binding DataContext.SelectFirstChoiceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    IsEnabled="{Binding DataContext.AreFirstChoicesEnabled, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>

                                    <!-- 두 번째 보기 -->
                                    <Border Grid.Row="2"
                                            Style="{StaticResource ChoiceGroupBorder}"
                                            VerticalAlignment="Stretch">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Text="두 번째 빈칸 보기"
                                                       Foreground="{StaticResource Brush.Text}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"/>

                                            <ScrollViewer Grid.Row="2"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding SecondChoices}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Columns="3"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Content="{Binding}"
                                                                    Style="{StaticResource ChoiceButton}"
                                                                    Command="{Binding DataContext.SelectSecondChoiceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    IsEnabled="{Binding DataContext.AreSecondChoicesEnabled, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>

                            <Grid Grid.Row="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="힌트"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding HintCommand}"
                                        IsEnabled="{Binding IsHintEnabled}"/>

                                <Button Grid.Column="2"
                                        Content="다시하기"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding RestartCommand}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>