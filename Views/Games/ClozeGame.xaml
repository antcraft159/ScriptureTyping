<UserControl x:Class="ScriptureTyping.Views.Games.ClozeGame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ScriptureTyping.Converters"
             Background="Transparent"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             ClipToBounds="False">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:ChoiceGroupCommandParameterConverter x:Key="ChoiceGroupCommandParameterConverter"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.84"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChoiceButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="TopCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="110"/>
        </Style>

        <Style x:Key="ChoiceGroupBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="VeryHardTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Border Margin="{StaticResource Layout.MenuSafeMargin}"
            Padding="20,0,0,0">

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="2"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="← 뒤로"
                                Width="{StaticResource Layout.CommonWidth}"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding BackCommand}"/>

                        <StackPanel Grid.Column="2"
                                    Orientation="Vertical">

                            <TextBlock Text="{Binding Title}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Text}"/>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          Style="{StaticResource TopCombo}"
                                          ItemsSource="{Binding Courses}"
                                          SelectedItem="{Binding SelectedCourse, Mode=TwoWay}"/>

                                <ComboBox Grid.Column="2"
                                          Style="{StaticResource TopCombo}"
                                          ItemsSource="{Binding Days}"
                                          SelectedItem="{Binding SelectedDay, Mode=TwoWay}"/>

                                <ComboBox Grid.Column="4"
                                          Style="{StaticResource TopCombo}"
                                          ItemsSource="{Binding DifficultyOptions}"
                                          SelectedItem="{Binding SelectedDifficulty, Mode=TwoWay}"/>

                                <Button Grid.Column="6"
                                        Content="적용"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ApplySelectionCommand}"/>

                                <TextBlock Grid.Column="8"
                                           Text="{Binding SelectionError}"
                                           Foreground="#EF4444"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           Margin="12,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectionError}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectionError}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{StaticResource Brush.Bg}"
                            CornerRadius="8"
                            Padding="14">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding ProgressText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding ScoreText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="4"
                                           Text="{Binding ComboText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="6"
                                           Text="{Binding DifficultyText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="8"
                                           Text="{Binding TimeLeftText}"
                                           Foreground="{StaticResource Brush.Text2}"
                                           FontSize="12"
                                           Visibility="{Binding IsTimeAttack, Converter={StaticResource BoolToVis}}"/>
                            </Grid>

                            <Border Grid.Row="2"
                                    Background="{StaticResource Brush.Surface}"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock Text="{Binding QuestionText}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource Brush.Text}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               LineHeight="26"/>

                                    <TextBlock Text="{Binding ReferenceText}"
                                               Margin="0,10,0,0"
                                               Foreground="{StaticResource Brush.Text2}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Grid.Row="4"
                                       Text="{Binding FeedbackText}"
                                       Foreground="{StaticResource Brush.Text2}"
                                       FontSize="25"
                                       TextWrapping="Wrap"/>

                            <Grid Grid.Row="6">
                                <!-- 매우 어려움 직접 입력 -->
                                <Border Background="{StaticResource Brush.Surface}"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14"
                                        Visibility="{Binding IsVeryHardInputVisible, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="보기 없이 직접 입력하세요. 본문 2칸 + 권/장/절 3칸"
                                                   Foreground="{StaticResource Brush.Text}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>

                                        <ScrollViewer Grid.Row="2"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding VeryHardInputs}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="2"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="6"
                                                                Padding="10"
                                                                CornerRadius="8"
                                                                Background="{StaticResource Brush.Bg}"
                                                                BorderBrush="{StaticResource Brush.Border}"
                                                                BorderThickness="1">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Label}"
                                                                           Foreground="{StaticResource Brush.Text2}"
                                                                           FontSize="13"/>
                                                                <TextBox Style="{StaticResource VeryHardTextBox}"
                                                                         Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <Button Grid.Row="4"
                                                Content="제출"
                                                Width="{StaticResource Layout.CommonWidth}"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding SubmitVeryHardAnswerCommand}"
                                                IsEnabled="{Binding CanSubmitVeryHardAnswer}"/>
                                    </Grid>
                                </Border>

                                <!-- 공통 다중 빈칸 보기 -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding AreChoiceGroupsVisible, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl ItemsSource="{Binding ChoiceGroups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ChoiceGroupBorder}"
                                                        Margin="0,0,0,12">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="8"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0"
                                                                   Text="{Binding Title}"
                                                                   Foreground="{StaticResource Brush.Text}"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"/>

                                                        <ItemsControl Grid.Row="2"
                                                                      ItemsSource="{Binding Choices}"
                                                                      Tag="{Binding}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <UniformGrid Columns="3"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>

                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Button Content="{Binding}"
                                                                            Style="{StaticResource ChoiceButton}"
                                                                            Command="{Binding DataContext.SelectChoiceGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            IsEnabled="{Binding DataContext.AreChoiceGroupsEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                                        <Button.CommandParameter>
                                                                            <MultiBinding Converter="{StaticResource ChoiceGroupCommandParameterConverter}">
                                                                                <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}" Path="Tag"/>
                                                                                <Binding/>
                                                                            </MultiBinding>
                                                                        </Button.CommandParameter>
                                                                    </Button>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <Grid Grid.Row="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="힌트"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding HintCommand}"
                                        IsEnabled="{Binding IsHintEnabled}"/>

                                <Button Grid.Column="2"
                                        Content="다시하기"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding RestartCommand}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>