<UserControl x:Class="ScriptureTyping.Views.RecitingMusic.RecitingMusicView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Margin="{StaticResource Layout.MenuSafeMargin}">
        <Grid Margin="24"
              Background="{StaticResource Brush.Bg}">

            <Border Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 제목 -->
                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,16">
                        <TextBlock FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Brush.Text}">
                            <TextBlock.Text>
                                <Binding Path="Title"
                                         FallbackValue="암송을 즐겁게"/>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource Brush.Text2}"
                                   FontSize="14"
                                   TextWrapping="Wrap">
                            <TextBlock.Text>
                                <Binding Path="Description"
                                         FallbackValue="노래 목록과 가사를 확인할 수 있습니다."/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <!-- 요약 카드 -->
                    <Grid Grid.Row="1"
                          Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                CornerRadius="14"
                                Padding="16"
                                Background="#1B1D23"
                                BorderBrush="#2A2E36"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="전체 곡 수"
                                           Foreground="#9CA3AF"
                                           FontSize="13"/>
                                <TextBlock Foreground="White"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0">
                                    <TextBlock.Text>
                                        <Binding Path="TotalCount"
                                                 FallbackValue="0"
                                                 TargetNullValue="0"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                CornerRadius="14"
                                Padding="16"
                                Background="#1B1D23"
                                BorderBrush="#2A2E36"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="현재 목록"
                                           Foreground="#9CA3AF"
                                           FontSize="13"/>
                                <TextBlock Foreground="White"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0">
                                    <TextBlock.Text>
                                        <Binding Path="FilteredCount"
                                                 FallbackValue="0"
                                                 TargetNullValue="0"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4"
                                CornerRadius="14"
                                Padding="16"
                                Background="#1B1D23"
                                BorderBrush="#2A2E36"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="준비됨"
                                           Foreground="#9CA3AF"
                                           FontSize="13"/>
                                <TextBlock Foreground="White"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0">
                                    <TextBlock.Text>
                                        <Binding Path="ReadyCount"
                                                 FallbackValue="0"
                                                 TargetNullValue="0"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6"
                                CornerRadius="14"
                                Padding="16"
                                Background="#1B1D23"
                                BorderBrush="#2A2E36"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="완료"
                                           Foreground="#9CA3AF"
                                           FontSize="13"/>
                                <TextBlock Foreground="White"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0">
                                    <TextBlock.Text>
                                        <Binding Path="CompletedCount"
                                                 FallbackValue="0"
                                                 TargetNullValue="0"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 필터 -->
                    <Border Grid.Row="2"
                            Margin="0,0,0,16"
                            CornerRadius="16"
                            Padding="16"
                            Background="#17191E"
                            BorderBrush="#2A2E36"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="과정"
                                       Foreground="{StaticResource Brush.Text}"
                                       FontWeight="SemiBold"/>

                            <ComboBox Grid.Column="1"
                                      Height="36"
                                      Margin="8,0,0,0"
                                      ItemsSource="{Binding Courses}"
                                      SelectedItem="{Binding SelectedCourse, Mode=TwoWay}"/>

                            <TextBlock Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Text="일차"
                                       Foreground="{StaticResource Brush.Text}"
                                       FontWeight="SemiBold"/>

                            <ComboBox Grid.Column="4"
                                      Height="36"
                                      Margin="8,0,0,0"
                                      ItemsSource="{Binding Days}"
                                      SelectedItem="{Binding SelectedDay, Mode=TwoWay}"/>

                            <Button Grid.Column="6"
                                    Height="36"
                                    Content="조회"
                                    Command="{Binding ApplyFilterCommand}"/>

                            <Button Grid.Column="8"
                                    Height="36"
                                    Content="초기화"
                                    Command="{Binding ResetFilterCommand}"/>

                            <TextBlock Grid.Column="9"
                                       Margin="16,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Text2}"
                                       FontSize="13">
                                <TextBlock.Text>
                                    <Binding Path="CurrentFilterText"
                                             FallbackValue="필터를 선택하세요."/>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- 본문 -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.6*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="1.4*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 목록 -->
                        <Border Grid.Column="0"
                                CornerRadius="16"
                                Padding="16"
                                Background="#17191E"
                                BorderBrush="#2A2E36"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="노래 목록"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,12"/>

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding FilteredItems}"
                                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          RowHeaderWidth="0"
                                          Background="#17191E"
                                          Foreground="White"
                                          FontSize="20"
                                          BorderThickness="0"
                                          RowBackground="#17191E"
                                          AlternatingRowBackground="#1D2027"
                                          HorizontalGridLinesBrush="#2A2E36"
                                          VerticalGridLinesBrush="#2A2E36">

                                    <DataGrid.Resources>
                                        <Style x:Key="DisplayTextStyle" TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </DataGrid.Resources>

                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#20242C"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="BorderBrush" Value="#2A2E36"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="Padding" Value="10,8"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>

                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="8,6"/>
                                        </Style>
                                    </DataGrid.CellStyle>

                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="BorderBrush" Value="#2A2E36"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Background" Value="#17191E"/>
                                        </Style>
                                    </DataGrid.RowStyle>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="번호"
                                                            Width="60"
                                                            ElementStyle="{StaticResource DisplayTextStyle}">
                                            <DataGridTextColumn.Binding>
                                                <Binding Path="Number" Mode="OneWay"/>
                                            </DataGridTextColumn.Binding>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="과정"
                                                            Width="90"
                                                            ElementStyle="{StaticResource DisplayTextStyle}">
                                            <DataGridTextColumn.Binding>
                                                <Binding Path="Course" Mode="OneWay"/>
                                            </DataGridTextColumn.Binding>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="일차"
                                                            Width="90"
                                                            ElementStyle="{StaticResource DisplayTextStyle}">
                                            <DataGridTextColumn.Binding>
                                                <Binding Path="Day" Mode="OneWay"/>
                                            </DataGridTextColumn.Binding>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="구절"
                                                            Width="220"
                                                            ElementStyle="{StaticResource DisplayTextStyle}">
                                            <DataGridTextColumn.Binding>
                                                <Binding Path="Reference" Mode="OneWay"/>
                                            </DataGridTextColumn.Binding>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="상태"
                                                            Width="100"
                                                            ElementStyle="{StaticResource DisplayTextStyle}">
                                            <DataGridTextColumn.Binding>
                                                <Binding Path="Status" Mode="OneWay"/>
                                            </DataGridTextColumn.Binding>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- 상세 / 가사 -->
                        <Border Grid.Column="2"
                                CornerRadius="16"
                                Padding="16"
                                Background="#17191E"
                                BorderBrush="#2A2E36"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="실시간 가사"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>

                                <!-- 재생 버튼 -->
                                <StackPanel Grid.Row="4"
                                            Orientation="Horizontal">
                                    <Button Width="90"
                                            Height="36"
                                            Margin="0,0,8,0"
                                            Content="재생"
                                            Command="{Binding PlaySelectedCommand}"/>

                                    <Button Width="90"
                                            Height="36"
                                            Content="정지"
                                            Command="{Binding StopPlaybackCommand}"/>
                                </StackPanel>

                                <!-- 재생 진행 표시 -->
                                <Grid Grid.Row="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Foreground="#9CA3AF"
                                                   FontSize="12"
                                                   Text="{Binding CurrentTimeText}"/>

                                        <TextBlock Grid.Column="2"
                                                   Foreground="#9CA3AF"
                                                   FontSize="12"
                                                   Text="{Binding TotalDurationText}"/>
                                    </Grid>

                                    <Slider Grid.Row="2"
                                            Height="24"
                                            Minimum="0"
                                            Maximum="{Binding PlaybackProgressMaximum, Mode=OneWay}"
                                            Value="{Binding SeekBarValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsMoveToPointEnabled="True"
                                            AutoToolTipPlacement="TopLeft"
                                            AutoToolTipPrecision="0"
                                            PreviewMouseLeftButtonDown="PlaybackSlider_PreviewMouseLeftButtonDown"
                                            PreviewMouseLeftButtonUp="PlaybackSlider_PreviewMouseLeftButtonUp"/>
                                </Grid>

                                <!-- 재생 상태 -->
                                <TextBlock Grid.Row="8"
                                           Foreground="#9CA3AF"
                                           FontSize="13"
                                           TextWrapping="Wrap">
                                    <TextBlock.Text>
                                        <Binding Path="PlaybackStatusText"
                                                 FallbackValue="곡을 선택하세요."/>
                                    </TextBlock.Text>
                                </TextBlock>

                                <TextBlock Grid.Row="10"
                                           Text="가사"
                                           Foreground="#9CA3AF"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>

                                <Border Grid.Row="12"
                                        Background="#0F131A"
                                        BorderBrush="#263041"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14">
                                    <TextBox Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="White"
                                        FontSize="20"
                                        FontWeight="SemiBold"
                                        TextWrapping="Wrap"
                                        AcceptsReturn="True"
                                        IsReadOnly="True"
                                        VerticalScrollBarVisibility="Auto"
                                        HorizontalScrollBarVisibility="Disabled"
                                        CaretBrush="Transparent">
                                        <TextBox.Text>
                                            <Binding Path="SelectedItem.LyricsPreview"
                                                Mode="OneWay"
                                                TargetNullValue="선택한 음악의 가사가 여기에 표시됩니다."
                                                FallbackValue="선택한 음악의 가사가 여기에 표시됩니다."/>
                                        </TextBox.Text>
                                    </TextBox>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>