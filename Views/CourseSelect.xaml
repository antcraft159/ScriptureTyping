<UserControl x:Class="ScriptureTyping.Views.CourseSelect"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:ScriptureTyping.Views.Behaviors"
             Background="{DynamicResource Brush.Bg}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             ClipToBounds="False">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Width="{StaticResource Layout.CommonWidth}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.84"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Padding="24"
            Margin="{StaticResource Layout.MenuSafeMargin}"
            Background="Transparent">

        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 상단 바 -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    HorizontalAlignment="Stretch">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="과정/일차"
                               Foreground="{DynamicResource Brush.Text2}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <Grid Grid.Column="1">
                        <ComboBox ItemsSource="{Binding Courses}"
                                  SelectedItem="{Binding SelectedCourse, Mode=TwoWay}"
                                  Height="32"
                                  MinWidth="70"/>

                        <TextBlock Text="선택"
                                   Foreground="{DynamicResource Brush.Text2}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,28,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCourse}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedCourse}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Grid.Column="4">
                        <ComboBox ItemsSource="{Binding Days}"
                                  SelectedItem="{Binding SelectedDay, Mode=TwoWay}"
                                  Height="32"
                                  MinWidth="70"/>

                        <TextBlock Text="선택"
                                   Foreground="{DynamicResource Brush.Text2}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,28,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedDay}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedDay}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Grid.Column="5"
                          Margin="18,7,0,0"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Foreground="{DynamicResource Brush.Text2}"
                                   TextWrapping="Wrap">
                            <Run Text="선택된 과정/일차: "/>
                            <Run Text="{Binding SelectedCourse}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding SelectedDay}"/>
                        </TextBlock>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding CourseErrorMessage}"
                                   Foreground="#EF4444"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextWrapping="NoWrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CourseErrorMessage}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CourseErrorMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="6"
                            Content="학습 시작"
                            Width="{StaticResource Layout.CommonWidth}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartLearningCommand}"/>
                </Grid>
            </Border>

            <!-- 본문 -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="160"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 구절 -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource Brush.Bg}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Typing.CurrentVerseRef}"
                                           Foreground="{DynamicResource Brush.Text2}"
                                           FontSize="20"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding Typing.CurrentVerseDisplayText}"
                                           Foreground="{DynamicResource Brush.Text}"
                                           FontSize="20"
                                           TextWrapping="Wrap"
                                           LineHeight="24"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Margin="12,0,0,0"
                                    MinWidth="92"
                                    Height="32"
                                    Style="{StaticResource PrimaryButton}"
                                    Content="{Binding Typing.VerseToggleButtonText}"
                                    Command="{Binding Typing.ToggleVerseHiddenCommand}"/>
                        </Grid>
                    </Border>

                    <!-- 입력 -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource Brush.Bg}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <Grid>
                            <TextBox x:Name="TypingBox"
                                     Text="{Binding Typing.UserTypedText, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="{DynamicResource Brush.Text}"
                                     CaretBrush="{DynamicResource Brush.Text}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="20"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     SpellCheck.IsEnabled="False"
                                     Padding="3,4,6,4"
                                     IsReadOnly="{Binding Typing.IsTypingLocked}"/>

                            <TextBlock Text="여기에 타이핑하세요…"
                                       Foreground="{DynamicResource Brush.Text2}"
                                       FontSize="20"
                                       IsHitTestVisible="False"
                                       Margin="8,6,0,0"
                                       VerticalAlignment="Top">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TypingBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=TypingBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="3"
                               Text="{Binding Typing.CurrentMistakeCount, Mode=OneWay, StringFormat=오타 {0}개}"
                               Foreground="{DynamicResource Brush.Text2}"
                               FontSize="13"
                               Margin="6,6,0,0"/>

                    <StackPanel Grid.Row="5"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="다음 구절"
                                Width="{StaticResource Layout.CommonWidth}"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding Typing.NextVerseCommand}"/>
                    </StackPanel>

                    <!-- 결과 패널 -->
                    <Border Grid.Row="7"
                            Background="{DynamicResource Brush.Bg}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Visibility="{Binding Typing.IsStatsVisible, Converter={StaticResource BoolToVis}}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="결과"
                                       Foreground="{DynamicResource Brush.Text}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding Typing.StatsSummary}"
                                       Foreground="{DynamicResource Brush.Text2}"
                                       FontSize="13"
                                       Margin="0,0,0,10"/>

                            <Grid Grid.Row="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 정답 -->
                                <Border Grid.Row="0"
                                        Grid.Column="0"
                                        Background="{DynamicResource Brush.Surface2}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="정답"
                                                   Foreground="{DynamicResource Brush.Text}"
                                                   FontWeight="SemiBold"
                                                   FontSize="20"
                                                   Margin="0,0,0,8"/>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding Typing.CorrectResults}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="8"
                                                                Margin="0,0,0,6"
                                                                CornerRadius="6"
                                                                Background="{DynamicResource Brush.Surface}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Ref}"
                                                                           Foreground="{DynamicResource Brush.Text2}"
                                                                           FontSize="12"/>
                                                                <TextBlock Text="{Binding Expected}"
                                                                           Foreground="{DynamicResource Brush.Text}"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,4,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <!-- 오답 -->
                                <Border Grid.Row="0"
                                        Grid.Column="2"
                                        Background="{DynamicResource Brush.Surface2}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="오답"
                                                   Foreground="{DynamicResource Brush.Text}"
                                                   FontWeight="SemiBold"
                                                   FontSize="20"
                                                   Margin="0,0,0,8"/>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding Typing.WrongResults}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="8"
                                                                Margin="0,0,0,6"
                                                                CornerRadius="6"
                                                                Background="{DynamicResource Brush.Surface}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Ref}"
                                                                           Foreground="{DynamicResource Brush.Text2}"
                                                                           FontSize="12"/>

                                                                <TextBlock Text="{Binding Expected}"
                                                                           Foreground="{DynamicResource Brush.Text}"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,4,0,0"/>

                                                                <Border Margin="0,8,0,0"
                                                                        Padding="8"
                                                                        CornerRadius="6"
                                                                        Background="{DynamicResource Brush.Surface2}"
                                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                                        BorderThickness="1">
                                                                    <StackPanel>
                                                                        <TextBlock FontSize="16"
                                                                                   Foreground="{DynamicResource Brush.Text}"
                                                                                   TextWrapping="Wrap"
                                                                                   FontFamily="D2Coding, Consolas"
                                                                                   behaviors:InlineTextBlockBehavior.InlinesSource="{Binding TypedDiffInlines}" />

                                                                        <TextBlock FontSize="14"
                                                                                   Foreground="{DynamicResource Brush.Text2}"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,6,0,0"
                                                                                   FontFamily="D2Coding, Consolas"
                                                                                   behaviors:InlineTextBlockBehavior.InlinesSource="{Binding CorrectHintInlines}" />
                                                                    </StackPanel>
                                                                </Border>

                                                                <TextBlock Text="{Binding MistakeCount, StringFormat=오타 {0}개}"
                                                                           Foreground="{DynamicResource Brush.Text2}"
                                                                           FontSize="12"
                                                                           Margin="0,6,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <!-- 아래: 비율 + 점수 -->
                                <Border Grid.Row="2"
                                        Grid.ColumnSpan="3"
                                        Background="{DynamicResource Brush.Surface2}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="{Binding Typing.CorrectRatePercent, StringFormat=정답 비율 {0}%}"
                                                       Foreground="{DynamicResource Brush.Text2}"
                                                       FontSize="20"
                                                       Margin="0,0,0,6"/>
                                            <ProgressBar Minimum="0"
                                                         Maximum="100"
                                                         Height="10"
                                                         Value="{Binding Typing.CorrectRatePercent, Mode=OneWay}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="2">
                                            <TextBlock Text="{Binding Typing.WrongRatePercent, StringFormat=오답 비율 {0}%}"
                                                       Foreground="{DynamicResource Brush.Text2}"
                                                       FontSize="20"
                                                       Margin="0,0,0,6"/>
                                            <ProgressBar Minimum="0"
                                                         Maximum="100"
                                                         Height="10"
                                                         Value="{Binding Typing.WrongRatePercent, Mode=OneWay}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="2"
                                                   Grid.ColumnSpan="3"
                                                   Text="{Binding Typing.ScoreOutOf100, StringFormat=점수: {0}점 / 100점}"
                                                   Foreground="{DynamicResource Brush.Text}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,10,0,0"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>