<UserControl x:Class="ScriptureTyping.Views.Games.SpeedTypingGame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel>
            <Button Content="← 뒤로" Height="32" Padding="14,0" Command="{Binding BackCommand}"/>
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" Margin="16,0,0,0" VerticalAlignment="Center"/>
        </DockPanel>

        <Border Grid.Row="2" Padding="16" CornerRadius="12" BorderThickness="1" BorderBrush="#30000000" Background="#10FFFFFF">
            <TextBlock Text="여기부터 '스피드 타이핑' UI/로직을 구현하면 됨." TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>