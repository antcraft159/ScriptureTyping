<UserControl x:Class="ScriptureTyping.Views.Games.GamesHub"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Margin="{StaticResource Layout.MenuSafeMargin}"
            Padding="20,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                   Text="게임"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

            <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

                <ItemsControl x:Name="GamesItems"
                          ItemsSource="{Binding Games}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- Columns는 코드비하인드에서 자동으로 바꿈 -->
                            <UniformGrid x:Name="GamesUniformGrid"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Width 고정하지 말고 MinWidth만 둬서, 칸에 맞춰 늘어나게 -->
                            <Border MinWidth="260"
                                Margin="8"
                                Padding="16"
                                CornerRadius="12"
                                BorderThickness="1"
                                BorderBrush="#30000000"
                                Background="DarkGray">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                           Text="{Binding Title}"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                    <TextBlock Grid.Row="1"
                                           Text="{Binding Description}"
                                           Opacity="0.85"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,12"/>

                                    <Button Grid.Row="2"
                                        Content="시작"
                                        Height="32"
                                        Padding="14,0"
                                        VerticalAlignment="Top"
                                        Command="{Binding StartCommand}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>