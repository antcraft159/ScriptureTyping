<Window x:Class="ScriptureTyping.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ScriptureTyping.ViewModels"
        xmlns:views="clr-namespace:ScriptureTyping.Views"
        Width="1200"
        Height="800"
        MinWidth="1200"
        MinHeight="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Bg}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <!-- TopBar -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Surface}"
                Padding="14,10">
            <DockPanel LastChildFill="True">

                <Button DockPanel.Dock="Right"
                        Width="110"
                        Height="32"
                        Margin="12,0,0,0"
                        Content="테마 변경"
                        Click="ThemeToggleButton_Click"
                        Background="{DynamicResource Brush.Surface2}"
                        Foreground="{DynamicResource Brush.Text}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        Cursor="Hand"
                        VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Width="52"
                            Height="32"
                            Margin="0,0,10,0"
                            Content="홈"
                            Command="{Binding GoHomeCommand}"
                            Background="{DynamicResource Brush.Surface2}"
                            Foreground="{DynamicResource Brush.Text}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            Cursor="Hand"
                            VerticalAlignment="Center"/>

                    <TextBlock Text="{Binding Title}"
                               Foreground="{DynamicResource Brush.Text}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main -->
        <Grid Grid.Row="1"
              Background="{DynamicResource Brush.Bg}"
              ClipToBounds="True">

            <ContentControl Content="{Binding CurrentContentViewModel}"
                            Margin="{StaticResource Layout.MenuPeekMargin}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"/>

            <!-- 홈 화면일 때만 보이는 메인 대시보드 -->
            <Grid Margin="{StaticResource Layout.MenuSafeMargin}"
                  Panel.ZIndex="100"
                  Visibility="{Binding IsHomeVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.85*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="1.25*"/>
                </Grid.ColumnDefinitions>

                <!-- 실시간 일정 안내 -->
                <Border Grid.Column="0"
                        Margin="24,24,0,400"
                        Padding="20"
                        CornerRadius="16"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="실시간 일정 안내"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Text}"/>

                        <Viewbox Grid.Row="2"
                                 Stretch="Uniform"
                                 StretchDirection="Both"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch">
                            <Grid Width="900"
                                  Height="320">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 왼쪽 날짜/시간 -->
                                <Border Grid.Column="0"
                                        Padding="18"
                                        CornerRadius="12"
                                        Background="{DynamicResource Brush.Surface2}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CurrentYearText}"
                                                       FontSize="30"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource Brush.Text}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                        </Grid>

                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CurrentMonthText}"
                                                       FontSize="30"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource Brush.Text}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Left"/>
                                        </Grid>

                                        <Grid Grid.Row="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CurrentDayText}"
                                                       FontSize="30"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource Brush.Text}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>

                                        <Grid Grid.Row="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="시간"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.Muted}"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CurrentClockText}"
                                                       FontSize="30"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource Brush.Text}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- 오른쪽 일정 정보 -->
                                <Border Grid.Column="2"
                                        Padding="18"
                                        CornerRadius="12"
                                        Background="{DynamicResource Brush.Surface2}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TodayScheduleText}"
                                                   Foreground="{DynamicResource Brush.Text}"
                                                   FontSize="18"
                                                   Margin="0,0,0,14"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding CurrentScheduleText}"
                                                   Foreground="{DynamicResource Brush.Text}"
                                                   FontSize="18"
                                                   Margin="0,0,0,14"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding NextScheduleText}"
                                                   Foreground="{DynamicResource Brush.Text}"
                                                   FontSize="18"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Viewbox>
                    </Grid>
                </Border>

                <!-- 주요일정 -->
                <Border Grid.Column="2"
                        Margin="0,24,24,24"
                        Padding="20"
                        CornerRadius="16"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="주요일정"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Text}"/>

                        <Border Grid.Row="2"
                                Background="{DynamicResource Brush.Bg}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12"
                                ClipToBounds="True">

                            <Grid>
                                <Image Source="{Binding PlanImagePath}"
                                       Stretch="Uniform"
                                       StretchDirection="Both"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       SnapsToDevicePixels="True"
                                       UseLayoutRounding="True"/>

                                <TextBlock Text="{Binding PlanImageMessage}"
                                           Foreground="{DynamicResource Brush.Muted}"
                                           FontSize="16"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="12"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <views:MainMenu DataContext="{Binding MenuViewModel}"
                            Panel.ZIndex="300"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"/>
        </Grid>

        <!-- StatusBar -->
        <Border Grid.Row="2"
                Background="{DynamicResource Brush.Surface}"
                Padding="14,6">
            <TextBlock Text="{Binding FooterRight}"
                       Foreground="{DynamicResource Brush.Muted}"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>