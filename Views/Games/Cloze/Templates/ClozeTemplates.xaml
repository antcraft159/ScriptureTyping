<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ItemsPanelTemplate x:Key="Cloze.WrapItemsPanel">
        <WrapPanel Orientation="Horizontal"/>
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="Cloze.VerticalItemsPanel">
        <StackPanel Orientation="Vertical"/>
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="Cloze.HorizontalItemsPanel">
        <StackPanel Orientation="Horizontal"/>
    </ItemsPanelTemplate>

    <DataTemplate x:Key="Cloze.HeaderTemplate">
        <Border Style="{StaticResource Cloze.CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Title}"
                                   Style="{StaticResource Cloze.TitleText}"/>
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding Subtitle}"
                                   Style="{StaticResource Cloze.SubText}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Border Margin="0,0,8,0"
                                Style="{StaticResource Cloze.BadgeBorder}">
                            <TextBlock Text="{Binding DifficultyName}"
                                       Style="{StaticResource Cloze.BadgeText}"/>
                        </Border>

                        <Border Style="{StaticResource Cloze.BadgeBorder}">
                            <TextBlock Text="{Binding CurrentRoundText}"
                                       Style="{StaticResource Cloze.BadgeText}"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ProgressBar Grid.Column="0"
                                 Height="10"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressValue}"
                                 Style="{StaticResource Cloze.ProgressBar}"/>

                    <TextBlock Grid.Column="1"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Text="{Binding ProgressText}"
                               Style="{StaticResource Cloze.SubText}"/>
                </Grid>

                <ContentPresenter Grid.Row="4"
                                  Content="{Binding HeaderExtraContent}"/>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="Cloze.DifficultyCardTemplate">
        <Button Style="{StaticResource Cloze.DifficultyCardButton}"
                Command="{Binding Command}"
                CommandParameter="{Binding CommandParameter}"
                IsEnabled="{Binding IsEnabled}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding Name}"
                           Style="{StaticResource Cloze.SectionTitleText}"/>

                <TextBlock Grid.Row="2"
                           Text="{Binding Description}"
                           Style="{StaticResource Cloze.BodyText}"/>

                <Border Grid.Row="4"
                        HorizontalAlignment="Left"
                        Style="{StaticResource Cloze.BadgeBorder}">
                    <TextBlock Text="{Binding Hint}"
                               Style="{StaticResource Cloze.BadgeText}"/>
                </Border>
            </Grid>
        </Button>
    </DataTemplate>

    <DataTemplate x:Key="Cloze.QuestionInfoTemplate">
        <Border Style="{StaticResource Cloze.SoftPanelBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding RefText}"
                               Style="{StaticResource Cloze.SectionTitleText}"/>
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding GuideText}"
                               Style="{StaticResource Cloze.SubText}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource Cloze.BadgeBorder}">
                    <TextBlock Text="{Binding RemainingText}"
                               Style="{StaticResource Cloze.BadgeText}"/>
                </Border>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="Cloze.ScriptureTemplate">
        <Border Style="{StaticResource Cloze.ScriptureContainer}">
            <TextBlock Text="{Binding DisplayVerse}"
                       Style="{StaticResource Cloze.ScriptureText}"/>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="Cloze.BlankItemTemplate">
        <Border x:Name="BlankBorder"
                Style="{StaticResource Cloze.BlankBox}">
            <TextBlock x:Name="BlankText"
                       Text="{Binding Text}"
                       Style="{StaticResource Cloze.BlankText}"/>
        </Border>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                <Setter TargetName="BlankBorder" Property="Background" Value="{StaticResource Cloze.SuccessSoft}"/>
                <Setter TargetName="BlankBorder" Property="BorderBrush" Value="{StaticResource Cloze.Success}"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsWrong}" Value="True">
                <Setter TargetName="BlankBorder" Property="Background" Value="{StaticResource Cloze.DangerSoft}"/>
                <Setter TargetName="BlankBorder" Property="BorderBrush" Value="{StaticResource Cloze.Danger}"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsFilled}" Value="False">
                <Setter TargetName="BlankText" Property="Text" Value="{Binding Placeholder}"/>
                <Setter TargetName="BlankText" Property="Foreground" Value="{StaticResource Cloze.TextHint}"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate x:Key="Cloze.OptionItemTemplate">
        <Button x:Name="OptionButton"
                Content="{Binding Text}"
                Command="{Binding Command}"
                CommandParameter="{Binding CommandParameter}"
                IsEnabled="{Binding IsEnabled}"
                Style="{StaticResource Cloze.OptionButton}"/>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter TargetName="OptionButton" Property="Background" Value="#FFEAF2FF"/>
                <Setter TargetName="OptionButton" Property="BorderBrush" Value="{StaticResource Cloze.Primary}"/>
                <Setter TargetName="OptionButton" Property="Foreground" Value="{StaticResource Cloze.Primary}"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                <Setter TargetName="OptionButton" Property="Background" Value="{StaticResource Cloze.SuccessSoft}"/>
                <Setter TargetName="OptionButton" Property="BorderBrush" Value="{StaticResource Cloze.Success}"/>
                <Setter TargetName="OptionButton" Property="Foreground" Value="{StaticResource Cloze.Success}"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsWrong}" Value="True">
                <Setter TargetName="OptionButton" Property="Background" Value="{StaticResource Cloze.DangerSoft}"/>
                <Setter TargetName="OptionButton" Property="BorderBrush" Value="{StaticResource Cloze.Danger}"/>
                <Setter TargetName="OptionButton" Property="Foreground" Value="{StaticResource Cloze.Danger}"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate x:Key="Cloze.OptionGroupTemplate">
        <Border Style="{StaticResource Cloze.OptionGroupBorder}">
            <StackPanel>
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource Cloze.SectionTitleText}"/>

                <ItemsControl Margin="0,14,0,0"
                              ItemsSource="{Binding Items}"
                              ItemTemplate="{StaticResource Cloze.OptionItemTemplate}"
                              ItemsPanel="{StaticResource Cloze.WrapItemsPanel}"/>
            </StackPanel>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="Cloze.InputAnswerTemplate">
        <Border Style="{StaticResource Cloze.OptionGroupBorder}">
            <StackPanel>
                <TextBlock Text="{Binding Label}"
                           Style="{StaticResource Cloze.SectionTitleText}"/>

                <TextBlock Margin="0,8,0,0"
                           Text="{Binding Placeholder}"
                           Style="{StaticResource Cloze.SubText}"/>

                <DockPanel Margin="0,14,0,0">
                    <Button DockPanel.Dock="Right"
                            Margin="10,0,0,0"
                            Content="확인"
                            Command="{Binding SubmitCommand}"
                            CommandParameter="{Binding SubmitCommandParameter}"
                            Style="{StaticResource Cloze.PrimaryButton}"/>

                    <TextBox Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Cloze.TextBox}"/>
                </DockPanel>
            </StackPanel>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="Cloze.BottomActionTemplate">
        <Border Style="{StaticResource Cloze.CardBorder}">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="{Binding LeftButtonText}"
                        Command="{Binding LeftCommand}"
                        CommandParameter="{Binding LeftCommandParameter}"
                        Style="{StaticResource Cloze.SecondaryButton}"/>

                <TextBlock Grid.Column="1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="{Binding CenterText}"
                           Style="{StaticResource Cloze.SubText}"/>

                <Button Grid.Column="2"
                        Content="{Binding RightButtonText}"
                        Command="{Binding RightCommand}"
                        CommandParameter="{Binding RightCommandParameter}"
                        Style="{StaticResource Cloze.PrimaryButton}"/>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="Cloze.ResultSummaryTemplate">
        <Border Style="{StaticResource Cloze.ResultSummaryBorder}">
            <StackPanel>
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource Cloze.TitleText}"/>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding SummaryText}"
                           Style="{StaticResource Cloze.SubText}"/>

                <UniformGrid Margin="0,18,0,0"
                             Columns="4">
                    <Border Margin="0,0,10,0"
                            Style="{StaticResource Cloze.SoftPanelBorder}">
                        <StackPanel>
                            <TextBlock Text="점수"
                                       Style="{StaticResource Cloze.SubText}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding ScoreText}"
                                       Style="{StaticResource Cloze.SectionTitleText}"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,10,0"
                            Style="{StaticResource Cloze.SoftPanelBorder}">
                        <StackPanel>
                            <TextBlock Text="정확도"
                                       Style="{StaticResource Cloze.SubText}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding AccuracyText}"
                                       Style="{StaticResource Cloze.SectionTitleText}"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,10,0"
                            Style="{StaticResource Cloze.SoftPanelBorder}">
                        <StackPanel>
                            <TextBlock Text="정답"
                                       Style="{StaticResource Cloze.SubText}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding CorrectCountText}"
                                       Style="{StaticResource Cloze.ResultCorrectText}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Cloze.SoftPanelBorder}">
                        <StackPanel>
                            <TextBlock Text="오답"
                                       Style="{StaticResource Cloze.SubText}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding WrongCountText}"
                                       Style="{StaticResource Cloze.ResultWrongText}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="Cloze.ResultItemTemplate">
        <Border Margin="0,0,0,10"
                Padding="14"
                CornerRadius="12"
                BorderThickness="1"
                Background="White"
                BorderBrush="{StaticResource Cloze.Border}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Top"
                           Text="{Binding Ref}"
                           Style="{StaticResource Cloze.SubText}"/>

                <StackPanel Grid.Column="1"
                            Margin="10,0,10,0">
                    <TextBlock Text="정답"
                               Style="{StaticResource Cloze.SubText}"/>
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding Expected}"
                               Style="{StaticResource Cloze.BodyText}"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Margin="10,0,10,0">
                    <TextBlock Text="입력"
                               Style="{StaticResource Cloze.SubText}"/>
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding Typed}"
                               Style="{StaticResource Cloze.BodyText}"/>
                </StackPanel>

                <StackPanel Grid.Column="3"
                            HorizontalAlignment="Right">
                    <Border x:Name="ResultBadge"
                            Style="{StaticResource Cloze.BadgeBorder}">
                        <TextBlock x:Name="ResultBadgeText"
                                   Text="오답"
                                   Style="{StaticResource Cloze.BadgeText}"/>
                    </Border>

                    <TextBlock Margin="0,8,0,0"
                               HorizontalAlignment="Right"
                               Text="{Binding MistakeCount, StringFormat=실수 {0}회}"
                               Style="{StaticResource Cloze.SubText}"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                <Setter TargetName="ResultBadge" Property="Background" Value="{StaticResource Cloze.SuccessSoft}"/>
                <Setter TargetName="ResultBadge" Property="BorderBrush" Value="{StaticResource Cloze.Success}"/>
                <Setter TargetName="ResultBadgeText" Property="Text" Value="정답"/>
                <Setter TargetName="ResultBadgeText" Property="Foreground" Value="{StaticResource Cloze.Success}"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                <Setter TargetName="ResultBadge" Property="Background" Value="{StaticResource Cloze.DangerSoft}"/>
                <Setter TargetName="ResultBadge" Property="BorderBrush" Value="{StaticResource Cloze.Danger}"/>
                <Setter TargetName="ResultBadgeText" Property="Text" Value="오답"/>
                <Setter TargetName="ResultBadgeText" Property="Foreground" Value="{StaticResource Cloze.Danger}"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate x:Key="Cloze.ResultListTemplate">
        <ItemsControl ItemsSource="{Binding}"
                      ItemTemplate="{StaticResource Cloze.ResultItemTemplate}"
                      ItemsPanel="{StaticResource Cloze.VerticalItemsPanel}"/>
    </DataTemplate>

    <DataTemplate x:Key="Cloze.EmptyStateTemplate">
        <Border Style="{StaticResource Cloze.CardBorder}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center"
                           Text="{Binding EmptyTitle}"
                           Style="{StaticResource Cloze.SectionTitleText}"/>
                <TextBlock Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           Text="{Binding EmptyMessage}"
                           Style="{StaticResource Cloze.SubText}"/>
            </StackPanel>
        </Border>
    </DataTemplate>

</ResourceDictionary>