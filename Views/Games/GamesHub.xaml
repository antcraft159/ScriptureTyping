<UserControl x:Class="ScriptureTyping.Views.Games.GamesHub"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="게임"
                   FontSize="26"
                   FontWeight="SemiBold"/>

        <ItemsControl Grid.Row="2" ItemsSource="{Binding Games}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="280"
                            Margin="0,0,16,16"
                            Padding="16"
                            CornerRadius="12"
                            BorderThickness="1"
                            BorderBrush="#30000000"
                            Background="#10FFFFFF">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Description}"
                                       Opacity="0.85"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>
                            <Button Content="시작"
                                    Height="32"
                                    Padding="14,0"
                                    Command="{Binding StartCommand}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>