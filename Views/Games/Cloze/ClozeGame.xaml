<UserControl x:Class="ScriptureTyping.Views.Games.ClozeGame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ScriptureTyping.Converters"
             xmlns:beh="clr-namespace:ScriptureTyping.Views.Behaviors"
             Background="Transparent"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             ClipToBounds="False">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:ChoiceGroupCommandParameterConverter x:Key="ChoiceGroupCommandParameterConverter"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.84"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChoiceButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Width" Value="170"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="TopCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="110"/>
        </Style>

        <Style x:Key="ChoiceGroupBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="VeryHardTextBox" TargetType="TextBox">
            <Setter Property="MinHeight" Value="100"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="SamuelRank1TextBox" TargetType="TextBox">
            <Setter Property="MinHeight" Value="180"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DifficultyListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="DifficultyListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface2}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="14,8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Margin="{StaticResource Layout.MenuSafeMargin}"
            Padding="20,0,0,0">

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="2"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="← 뒤로"
                                Width="{StaticResource Layout.CommonWidth}"
                                Height="70"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding BackCommand}"/>

                        <StackPanel Grid.Column="2"
                                    Orientation="Vertical">

                            <TextBlock Text="{Binding Title}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.Text}"/>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          Style="{StaticResource TopCombo}"
                                          ItemsSource="{Binding Courses}"
                                          SelectedItem="{Binding SelectedCourse, Mode=TwoWay}"/>

                                <ComboBox Grid.Column="2"
                                          Style="{StaticResource TopCombo}"
                                          ItemsSource="{Binding Days}"
                                          SelectedItem="{Binding SelectedDay, Mode=TwoWay}"/>

                                <ListBox Grid.Column="4"
                                         Style="{StaticResource DifficultyListBox}"
                                         ItemContainerStyle="{StaticResource DifficultyListBoxItem}"
                                         ItemsSource="{Binding DifficultyOptions}"
                                         SelectedItem="{Binding SelectedDifficulty, Mode=TwoWay}"
                                         SelectionMode="Single"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         MinHeight="32">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                </ListBox>

                                <Button Grid.Column="6"
                                        Content="적용"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ApplySelectionCommand}"/>

                                <TextBlock Grid.Column="8"
                                           Text="{Binding SelectionError}"
                                           Foreground="#EF4444"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           Margin="12,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectionError}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectionError}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{DynamicResource Brush.Bg}"
                            CornerRadius="8"
                            Padding="14">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding ProgressText}"
                                           Foreground="{DynamicResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding ScoreText}"
                                           Foreground="{DynamicResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="4"
                                           Text="{Binding ComboText}"
                                           Foreground="{DynamicResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="6"
                                           Text="{Binding DifficultyText}"
                                           Foreground="{DynamicResource Brush.Text2}"
                                           FontSize="12"/>

                                <TextBlock Grid.Column="8"
                                           Text="{Binding TimeLeftText}"
                                           Foreground="{DynamicResource Brush.Text2}"
                                           FontSize="12"
                                           Visibility="{Binding IsTimeAttack, Converter={StaticResource BoolToVis}}"/>
                            </Grid>

                            <Border Grid.Row="2"
                                    Background="{DynamicResource Brush.Surface}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14">

                                <StackPanel>
                                    <TextBlock Text="{Binding QuestionText}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource Brush.Text}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               LineHeight="26">

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSamuelRank1InputVisible}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding QuestionText}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Text="{Binding ReferenceText}"
                                               FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Margin" Value="0,10,0,0"/>
                                                <Setter Property="FontSize" Value="16"/>
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text2}"/>
                                                <Setter Property="TextAlignment" Value="Left"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSamuelRank1InputVisible}" Value="True">
                                                        <Setter Property="Margin" Value="0"/>
                                                        <Setter Property="FontSize" Value="24"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                                                        <Setter Property="TextAlignment" Value="Center"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="6">
                                <Border Background="{DynamicResource Brush.Surface}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14"
                                        Visibility="{Binding IsSamuelRank1InputVisible, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="권/장/절만 보고 말씀 전체를 입력하세요."
                                                   Foreground="{DynamicResource Brush.Text}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Grid.Row="2"
                                                   Text="보기 없이 직접 암송합니다. 띄어쓰기와 문장부호 차이는 자동 보정됩니다."
                                                   Foreground="{DynamicResource Brush.Text2}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"/>

                                        <TextBox Grid.Row="4"
                                                 Style="{StaticResource SamuelRank1TextBox}"
                                                 beh:TextBoxPasteBlockBehavior.IsPasteBlocked="True"
                                                 Text="{Binding SamuelRank1InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <Button Grid.Row="6"
                                                Content="제출"
                                                Width="{StaticResource Layout.CommonWidth}"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding SubmitSamuelRank1AnswerCommand}"
                                                IsEnabled="{Binding CanSubmitSamuelRank1Answer}"/>
                                    </Grid>
                                </Border>

                                <Border Background="{DynamicResource Brush.Surface}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14"
                                        Visibility="{Binding IsVeryHardInputVisible, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="문장의 빈칸을 직접 입력하세요."
                                                   Foreground="{DynamicResource Brush.Text}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Grid.Row="2"
                                                   Text="매우 어려움은 보기 없이 진행됩니다. 빈칸 수가 많을 수 있습니다."
                                                   Foreground="{DynamicResource Brush.Text2}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"/>

                                        <ScrollViewer Grid.Row="4"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding VeryHardInputs}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="320"
                                                                MinHeight="150"
                                                                Margin="0,0,12,12"
                                                                Padding="10"
                                                                CornerRadius="8"
                                                                Background="{DynamicResource Brush.Bg}"
                                                                BorderBrush="{DynamicResource Brush.Border}"
                                                                BorderThickness="1">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Label}"
                                                                           Foreground="{DynamicResource Brush.Text2}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"/>
                                                                <TextBox Style="{StaticResource VeryHardTextBox}"
                                                                         beh:TextBoxPasteBlockBehavior.IsPasteBlocked="True"
                                                                         Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <Button Grid.Row="6"
                                                Content="제출"
                                                Width="{StaticResource Layout.CommonWidth}"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding SubmitVeryHardAnswerCommand}"
                                                IsEnabled="{Binding CanSubmitVeryHardAnswer}"/>
                                    </Grid>
                                </Border>

                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding AreChoiceGroupsVisible, Converter={StaticResource BoolToVis}}">

                                    <ItemsControl ItemsSource="{Binding ChoiceGroups}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ChoiceGroupBorder}"
                                                        Margin="0,0,12,12"
                                                        Width="210">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="8"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0"
                                                                   Text="{Binding Title}"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#22C55E"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding SelectedChoice}" Value="{x:Null}">
                                                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding SelectedChoice}" Value="">
                                                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <ItemsControl Grid.Row="2"
                                                                      ItemsSource="{Binding Choices}"
                                                                      Tag="{Binding}"
                                                                      HorizontalAlignment="Center">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>

                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Button Content="{Binding}"
                                                                            Style="{StaticResource ChoiceButton}"
                                                                            Command="{Binding DataContext.SelectChoiceGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            IsEnabled="{Binding DataContext.AreChoiceGroupsEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                                        <Button.CommandParameter>
                                                                            <MultiBinding Converter="{StaticResource ChoiceGroupCommandParameterConverter}">
                                                                                <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}" Path="Tag"/>
                                                                                <Binding/>
                                                                            </MultiBinding>
                                                                        </Button.CommandParameter>
                                                                    </Button>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <Grid Grid.Row="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="힌트"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding HintCommand}"
                                        IsEnabled="{Binding IsHintEnabled}"/>

                                <Button Grid.Column="2"
                                        Content="다시하기"
                                        Width="{StaticResource Layout.CommonWidth}"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding RestartCommand}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>