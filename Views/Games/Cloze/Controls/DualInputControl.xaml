<UserControl x:Class="ScriptureTyping.Views.Games.Cloze.Controls.DualInputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             MinWidth="320"
             MinHeight="140">
    <Border Background="{Binding BackgroundBrush, ElementName=Root}"
            BorderBrush="{Binding BorderBrushEx, ElementName=Root}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 상단 입력 -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding FirstTitle, ElementName=Root}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{Binding TitleForeground, ElementName=Root}"
                           Margin="2,0,0,0"/>

                <Grid Grid.Row="2">
                    <Border Background="{Binding InputBackgroundBrush, ElementName=Root}"
                            BorderBrush="{Binding InputBorderBrush, ElementName=Root}"
                            BorderThickness="1"
                            CornerRadius="10"/>

                    <TextBox x:Name="PART_FirstTextBox"
                             Margin="12,8"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{Binding InputForeground, ElementName=Root}"
                             CaretBrush="{Binding CaretBrushEx, ElementName=Root}"
                             FontSize="16"
                             FontWeight="SemiBold"
                             VerticalContentAlignment="Center"
                             Text="{Binding FirstText, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsFirstEnabled, ElementName=Root}"
                             MaxLength="{Binding FirstMaxLength, ElementName=Root}"
                             PreviewKeyDown="OnFirstTextBoxPreviewKeyDown"/>

                    <TextBlock Margin="14,10"
                               Text="{Binding FirstPlaceholder, ElementName=Root}"
                               Foreground="{Binding PlaceholderForeground, ElementName=Root}"
                               FontSize="14"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FirstText, ElementName=Root}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FirstText, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>

            <!-- 하단 입력 -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding SecondTitle, ElementName=Root}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{Binding TitleForeground, ElementName=Root}"
                           Margin="2,0,0,0"/>

                <Grid Grid.Row="2">
                    <Border Background="{Binding InputBackgroundBrush, ElementName=Root}"
                            BorderBrush="{Binding InputBorderBrush, ElementName=Root}"
                            BorderThickness="1"
                            CornerRadius="10"/>

                    <TextBox x:Name="PART_SecondTextBox"
                             Margin="12,8"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{Binding InputForeground, ElementName=Root}"
                             CaretBrush="{Binding CaretBrushEx, ElementName=Root}"
                             FontSize="16"
                             FontWeight="SemiBold"
                             VerticalContentAlignment="Center"
                             Text="{Binding SecondText, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsSecondEnabled, ElementName=Root}"
                             MaxLength="{Binding SecondMaxLength, ElementName=Root}"
                             PreviewKeyDown="OnSecondTextBoxPreviewKeyDown"/>

                    <TextBlock Margin="14,10"
                               Text="{Binding SecondPlaceholder, ElementName=Root}"
                               Foreground="{Binding PlaceholderForeground, ElementName=Root}"
                               FontSize="14"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SecondText, ElementName=Root}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SecondText, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>